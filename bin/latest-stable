#!/usr/bin/env bash

# Print the single highest stable mdsmith version, optionally filtered
# by the version prefix asdf passes as $1 (e.g. `asdf latest mdsmith 0`).
# Pre-release tags (-rc, -alpha, ...) are excluded.

set -euo pipefail

current_script_path="${BASH_SOURCE[0]}"
plugin_dir="$(dirname "$(dirname "$current_script_path")")"

# shellcheck source=../lib/utils.bash
source "${plugin_dir}/lib/utils.bash"

query="${1:-}"

versions="$(list_all_versions | grep -viE '(^|[-.])(rc|alpha|beta|pre|dev|snapshot)')"
if [ -n "$query" ]; then
	versions="$(echo "$versions" | grep -E "^${query}" || true)"
fi

echo "$versions" | sort_versions | tail -n1

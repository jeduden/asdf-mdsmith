#!/usr/bin/env bash
set -euo pipefail

version="${ASDF_INSTALL_VERSION:-${1:-}}"
download_path="${ASDF_DOWNLOAD_PATH:-${2:-}}"
install_path="${ASDF_INSTALL_PATH:-${3:-}}"

if [[ -z "${version}" || -z "${download_path}" || -z "${install_path}" ]]; then
  echo "Usage: ASDF_INSTALL_VERSION=<version> ASDF_DOWNLOAD_PATH=<path> ASDF_INSTALL_PATH=<path> $0" >&2
  exit 1
fi

kernel="$(uname -s | tr '[:upper:]' '[:lower:]')"
arch="$(uname -m)"

case "${kernel}" in
  linux|darwin) os="${kernel}" ;;
  msys*|mingw*|cygwin*|windowsnt) os="windows" ;;
  *)
    echo "Unsupported operating system: ${kernel}" >&2
    exit 1
    ;;
esac

case "${arch}" in
  x86_64|amd64) asset_arch="amd64" ;;
  aarch64|arm64) asset_arch="arm64" ;;
  *)
    echo "Unsupported architecture: ${arch}" >&2
    exit 1
    ;;
esac

asset_name="mdsmith-${os}-${asset_arch}"
if [[ "${os}" == "windows" ]]; then
  asset_name+=".exe"
fi

if [[ ! -f "${download_path}/${asset_name}" ]]; then
  echo "Missing downloaded asset: ${download_path}/${asset_name}" >&2
  exit 1
fi

if [[ ! -f "${download_path}/checksums.txt" ]]; then
  echo "Missing checksum file: ${download_path}/checksums.txt" >&2
  exit 1
fi

(
  cd "${download_path}"
  grep "  ${asset_name}$" checksums.txt | sha256sum -c -
)

mkdir -p "${install_path}/bin"
install -m 0755 "${download_path}/${asset_name}" "${install_path}/bin/mdsmith"
